# =============================================================================
# infra/.env.deploy — non-secret runtime config for example-deepagents-dev
# =============================================================================
# This is the SINGLE SOURCE OF TRUTH for the deployed container's non-secret
# environment variables. infra/deploy.sh parses this file and injects every
# active line below into the Container App as the Bicep `appEnv` array param.
#
# HOW TO USE:
#   edit the values below, then:  make deploy   (or ./infra/deploy.sh)
# This file is COMMITTED to the repo — it is the one place to change non-secret
# runtime config; there is no .example template and no copy step. For a separate
# environment, copy this file and point deploy.sh at it:
#   ENV_FILE=infra/.env.deploy.stage make deploy
#
# FORMAT: KEY=VALUE, one per line. The first '=' separates key and value, so
# JSON values keep their ':' and ',' verbatim. '#' lines and blanks are ignored.
# Each non-comment line MUST use a var name the app actually reads (these match
# the verified-deployed set). Do NOT wrap values in quotes unless the value
# itself needs them (one surrounding quote pair is stripped).
#
# ⚠ SECRETS DO NOT GO HERE. The keys listed under "Bicep-owned" at the bottom are
# set by main.bicep / Key Vault. deploy.sh strips them if present (and warns), so
# adding them here does nothing except trigger a warning.
# =============================================================================

# --- App / runtime -----------------------------------------------------------
APP_ENV=dev
APP_LOG_LEVEL=INFO
AGENT_NAME=example-deepagents-dev
AGENT_DESCRIPTION=EXAMPLE DeepAgents orchestration backend
# AGENT_MAX_STEPS is legacy/cosmetic; LANGGRAPH_DEFAULT_RECURSION_LIMIT is the
# ENFORCED deep-agent step ceiling (super-steps, ~2 per model/tool cycle).
AGENT_MAX_STEPS=300
LANGGRAPH_DEFAULT_RECURSION_LIMIT=300
AGENT_HTTP_RETRY_MAX_ATTEMPTS=3
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Auth: AGENT_AUTH_* (primary, read by src/v1/utils/auth.py) --------------
AGENT_AUTH_MODE=jwt
AGENT_AUTH_ISSUER=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000/v2.0
AGENT_AUTH_AUDIENCE=api://11111111-1111-1111-1111-111111111111
AGENT_AUTH_ALLOWED_AUDIENCES=api://11111111-1111-1111-1111-111111111111,11111111-1111-1111-1111-111111111111
AGENT_AUTH_TENANT=00000000-0000-0000-0000-000000000000
AGENT_AUTH_JWKS_URL=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000/discovery/v2.0/keys
# JWT validation tuning (read by src/v1/utils/auth.py). Each equals the in-code
# default; set explicitly so the deployed jwt-mode validation params are visible
# in the source of truth rather than implicit.
AGENT_AUTH_ALGORITHMS=RS256
AGENT_AUTH_CLOCK_SKEW_SECONDS=60
AGENT_AUTH_JWKS_CACHE_SECONDS=300
AGENT_AUTH_REQUIRED_SCOPES=access_as_user
AGENT_AUTH_DEV_SUBJECT=postman-tester
AGENT_AUTH_DEV_TENANT=dev-tenant
AGENT_AUTH_GRAPH_GROUPS_FALLBACK=true
# TTL for the per-oid Graph getMemberGroups cache (src/v1/utils/graph_groups.py).
# Equals the code default; deploy exercises Graph group resolution (fallback +
# OBO below), so pin it explicitly.
GRAPH_GROUPS_CACHE_SECONDS=900
# On-behalf-of (OBO) group resolution. This toggle is the NON-secret half; OBO
# only actually activates when the ENTRA_CLIENT_SECRET secret is also present
# (Key Vault `entra-client-secret`, wired by main.bicep). Without the secret the
# app falls back to the managed-identity app-only Graph call.
AGENT_AUTH_GROUPS_OBO=true

# --- Auth: ENTRA_* (read by src/v1/core/config.py and as auth.py fallback) ----
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=11111111-1111-1111-1111-111111111111
ENTRA_AUDIENCE=api://11111111-1111-1111-1111-111111111111
ENTRA_ISSUER=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000/v2.0
ENTRA_JWKS_URL=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000/discovery/v2.0/keys
ENTRA_ALLOWED_AUDIENCES=api://11111111-1111-1111-1111-111111111111,11111111-1111-1111-1111-111111111111
ENTRA_GROUP_CLAIM=groups

# --- Tenant routing (JSON, single line each) ---------------------------------
# Entra group id/name -> Azure AI Search index. Members get that index; others
# fall back to AZURE_AI_SEARCH_DEFAULT_INDEX.
TENANT_GROUP_INDEX_MAPPING={"EXAMPLE-GROUP-INT":"example-rag-index","EXAMPLE-GROUP-EXT":"example-rag-index-iorm"}
# Entra group id/name -> that group's starter prompts ([{label, message}]).
# Callers matching no mapped group get no starter prompts (no built-in fallback).
# Default is empty. Example of the shape (replace the {} to enable):
# TENANT_GROUP_STARTER_PROMPTS_MAPPING={"<group>":[{"label":"Example","message":"Example starter prompt."}]}
TENANT_GROUP_STARTER_PROMPTS_MAPPING={}

# Comma-separated Entra groups (object-id or display name) for which the
# ServiceNow ticket subagent is DISABLED. IORM / external (EXAMPLE-GROUP-EXT)
# loses ServiceNow; DEPS / internal (EXAMPLE-GROUP-INT) keeps it. Empty =
# enabled for everyone.
SERVICENOW_DISABLED_GROUPS=EXAMPLE-GROUP-EXT

# Client-specific incident API path — the code default is a neutral placeholder,
# so every real environment MUST set this.
SERVICENOW_INCIDENT_LIST_API_PREFIX=/api/example-client/v1/example_support/incidents

AZURE_OPENAI_ENDPOINT=https://example-openai-resource.cognitiveservices.azure.com
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.1
# MUST exist on the resource — AI Search embeds every query with it.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-10-21
# Embedding api-version (config.py azure_openai_embedding_version). Equals the
# code default; pinned explicitly because AI Search embeds every query with it.
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01
# Use the user-assigned managed identity (example-chat-agent-mi-dev) for BOTH Azure
# OpenAI and Azure AI Search instead of static API keys. The MI holds Cognitive
# Services OpenAI User (on example-openai-resource) + Search Index Data Reader, so
# token auth works for chat, embeddings, and search. Using the search API key
# would bypass Azure RBAC entirely, so MI is required before any index-level
# RBAC/per-group access control can be enforced.
AZURE_OPENAI_USE_MANAGED_IDENTITY=true
AZURE_USE_MANAGED_IDENTITY=true

# --- Azure AI Search ---------------------------------------------------------
AZURE_AI_SEARCH_ENDPOINT=https://examplesearch.search.windows.net
AZURE_AI_SEARCH_DEFAULT_INDEX=example-rag-index
# NOTE: AZURE_AI_SEARCH_USE_MANAGED_IDENTITY is DEAD config — the app reads no such
# var. Search MI-vs-key is controlled by AZURE_USE_MANAGED_IDENTITY above. (left as a
# comment so nobody re-adds it expecting it to switch search auth.)
AZURE_SEARCH_SELECT_FIELDS=id,chunk_content,document_title,source_url,file_name,breadcrumb,page_number,source_type,last_modified
# Per-index semantic configuration. The semantic config name is a property of the
# INDEX, not the group: example-rag-index defines 'custom-kb-semantic-config' and
# example-rag-index-iorm defines 'example-rag-semantic-config-iorm'. Because the two
# tenant groups route to different indexes (TENANT_GROUP_INDEX_MAPPING above),
# each index MUST send its own config name. Sending one global name makes Azure
# 400 ("Unknown semantic configuration") on the index that doesn't define it,
# which silently kills RAG for that group. Any index not listed here falls back
# to AI_SEARCH_SEMANTIC_CONFIGURATION below (which covers the default index).
INDEX_SEMANTIC_CONFIG_MAPPING={"example-rag-index":"custom-kb-semantic-config","example-rag-index-iorm":"example-rag-semantic-config-iorm"}
# Default semantic config (used for the default index / any index unmapped above).
AI_SEARCH_SEMANTIC_CONFIGURATION=custom-kb-semantic-config
AI_SEARCH_MIN_RERANKER_SCORE=1.7
AZURE_VECTOR_FIELD_NAME=content_vector

# --- LangSmith (also satisfies the platform server's self-hosted-lite license) -
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=example-deepagents-dev

# --- ServiceNow (mock needs no credentials) ----------------------------------
# For live mode, set SERVICENOW_MODE=live and add the non-secret URLs here; the
# app resolves servicenow-client-id / servicenow-client-secret from Key Vault.
SERVICENOW_MODE=mock
SERVICENOW_FALLBACK_TO_MOCK=true

# =============================================================================
# Bicep-owned — DO NOT set these here (deploy.sh strips them and warns).
# Listed for reference so you know where they come from:
#   PERSISTENCE_BACKEND     main.bicepparam (coupled to POSTGRESS_DATABASE_URL)
#   AZURE_KEY_VAULT_URI     derived from the Key Vault resource
#   AZURE_CLIENT_ID         derived from the user-assigned managed identity
#   DATABASE_URI            in-env Postgres DSN (or KV ref agent-server-postgres-dsn)
#   REDIS_URI               in-env redis://…-redis:6379 (or KV ref agent-server-redis-url)
#   POSTGRESS_DATABASE_URL  app checkpointer DSN, wired when PERSISTENCE_BACKEND=postgres
# Secrets (Key Vault references on the container app):
#   AZURE_OPENAI_API_KEY    -> KV secret azure-openai-api-key
#   AZURE_AI_SEARCH_API_KEY -> KV secret azure-ai-search-api-key
#   LANGSMITH_API_KEY       -> KV secret langsmith-api-key
#   ENTRA_CLIENT_SECRET     -> KV secret entra-client-secret (activates OBO; pair
#                              with AGENT_AUTH_GROUPS_OBO=true above)
# =============================================================================
