# =============================================================================
# DeepAgent / LangGraph Agent Orchestration — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in the placeholder values (<...>) for the
# services you actually use. Do NOT commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# App / runtime
# -----------------------------------------------------------------------------
APP_ENV=local
AGENT_NAME=example-deepagent
AGENT_DESCRIPTION=example assistant with snow and azure ai search
AGENT_MAX_STEPS=50

# Comma-separated list (or JSON array) of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# -----------------------------------------------------------------------------
# Database / checkpointer
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deepagent?sslmode=disable
ENABLE_POSTGRES_CHECKPOINTER=false
PERSISTENCE_BACKEND=memory

# Auth: when true, uses DefaultAzureCredential (managed identity / az login).
# When false, set AZURE_OPENAI_API_KEY below.
AZURE_USE_MANAGED_IDENTITY=true
# AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-chat-latest
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01

# -----------------------------------------------------------------------------
# Azure AI Search
# -----------------------------------------------------------------------------

AZURE_AI_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_AI_SEARCH_DEFAULT_INDEX=<your-index-name>
AZURE_VECTOR_FIELD_NAME=content_vector
AZURE_SEARCH_SELECT_FIELDS='id,chunk_content,document_title,source_url,file_name,breadcrumb,page_number,source_type,last_modified'
AZURE_SEARCH_SEMANTIC_CONFIGURATION=custom-kb-semantic-config
AZURE_SEARCH_RERANKER_SCORE_THRESHOLD=1.2
# Per-request connect/read timeout (seconds) for Azure AI Search. SDK default is 300s.
AZURE_SEARCH_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Entra ID (Azure AD) auth — leave blank to disable JWT verification locally
# -----------------------------------------------------------------------------
# ENTRA_TENANT_ID=<your-tenant-id>
# ENTRA_CLIENT_ID=<your-client-id>
# Accept both the api:// App ID URI and the bare client-ID GUID (Entra v2.0
# tokens carry the bare GUID as `aud`). Var name must be ENTRA_ALLOWED_AUDIENCES.
# ENTRA_ALLOWED_AUDIENCES=api://<your-client-id>,<your-client-id>
# # ENTRA_ISSUER and ENTRA_JWKS_URL must be valid URLs or omitted (empty fails validation)
# ENTRA_ISSUER=https://login.microsoftonline.com/<your-tenant-id>/v2.0
# ENTRA_JWKS_URL=https://login.microsoftonline.com/<your-tenant-id>/discovery/v2.0/keys
# ENTRA_REQUIRED_SCOPES=
# ENTRA_GROUP_CLAIM=groups

# JSON object mapping Entra group IDs/names -> Azure AI Search index names.
TENANT_GROUP_INDEX_MAPPING={"EXAMPLE-GROUP-INT":"example-rag-index","EXAMPLE-GROUP-EXT":"example-rag-index-iorm"}

# JSON object mapping Entra group IDs/names -> that group's starter prompts.
# First matching key wins (declaration order). Unmapped callers get NO starter
# prompts (there is no built-in fallback).
TENANT_GROUP_STARTER_PROMPTS_MAPPING={}

# Comma-separated Entra groups (object-id or display name) for which the
# ServiceNow ticket subagent is DISABLED. IORM / external (EXAMPLE-GROUP-EXT)
# loses ServiceNow; DEPS / internal (EXAMPLE-GROUP-INT) keeps it. Empty =
# enabled for everyone.
SERVICENOW_DISABLED_GROUPS=EXAMPLE-GROUP-EXT


# -----------------------------------------------------------------------------
# Agent auth (AGENT_AUTH_*). For local dev, "dev" mode skips JWT verification.
# -----------------------------------------------------------------------------
AGENT_AUTH_MODE=jwt
AGENT_AUTH_DEV_SUBJECT=postman-tester
AGENT_AUTH_DEV_TENANT=<your-tenant-id>
AGENT_AUTH_REQUIRED_SCOPES=access_as_user
AGENT_AUTH_ISSUER=https://login.microsoftonline.com/<your-tenant-id>/v2.0
AGENT_AUTH_ALLOWED_AUDIENCES=api://<your-client-id>,<your-client-id>
AGENT_AUTH_JWKS_URL=https://login.microsoftonline.com/<your-tenant-id>/discovery/v2.0/keys
AGENT_AUTH_ALGORITHMS=RS256
AGENT_AUTH_CLOCK_SKEW_SECONDS=60
AGENT_AUTH_JWKS_CACHE_SECONDS=300
# When a token carries no `groups` claim, fall back to Microsoft Graph to resolve
# the caller's transitive group memberships.
AGENT_AUTH_GRAPH_GROUPS_FALLBACK=true
GRAPH_GROUPS_CACHE_SECONDS=900

# --- Group resolution via on-behalf-of (OBO), preferred --------------------
# When ENTRA_CLIENT_SECRET (below) is set alongside ENTRA_CLIENT_ID/ENTRA_TENANT_ID,
# the BE exchanges the caller's access token for a *delegated* Graph token and
# reads groups via /me/transitiveMemberOf — acting AS THE USER, so the identity is
# the same locally and in a container (no managed-identity trap). Requires the
# DELEGATED permission GroupMember.Read.All (admin-consented) on the app
# registration. Set OBO off to force the app-only /users/{oid} path instead.
AGENT_AUTH_GROUPS_OBO=true
# Confidential-client secret for OBO. Prefer Key Vault: set AZURE_KEY_VAULT_URI and
# store the secret as `entra-client-secret` (or set ENTRA_CLIENT_SECRET_SECRET_NAME).
# ENTRA_CLIENT_SECRET=<your-client-secret>
# Override the OBO Graph scope if you don't use admin-consented .default:
# ENTRA_GRAPH_OBO_SCOPE=https://graph.microsoft.com/GroupMember.Read.All
# When OBO is NOT configured, the app-only path is used instead — that requires the
# APPLICATION permission GroupMember.Read.All (admin-consented) on the managed identity.

# -----------------------------------------------------------------------------
# ServiceNow integration — "mock" needs no credentials
# -----------------------------------------------------------------------------
SERVICENOW_MODE=mock
SERVICENOW_FALLBACK_TO_MOCK=true
# SERVICENOW_INSTANCE_URL=https://<instance>.service-now.com
# SERVICENOW_INCIDENT_LIST_API_PREFIX=/api/<client>/v1/example_support/incidents
# SERVICENOW_TOKEN_URL=
# SERVICENOW_OAUTH_SCOPE=
# SERVICENOW_CLIENT_ID=
# SERVICENOW_CLIENT_SECRET=
# SERVICENOW_TIMEOUT_SECONDS=20
# SERVICENOW_VERIFY_SSL=true
# SERVICENOW_MOCK_FIXTURE_PATH=
# Default page size when a query omits limit (clamped 1-25; fallback 10)
# SERVICENOW_DEFAULT_LIMIT=10

# -----------------------------------------------------------------------------
# Azure Key Vault (required to source secrets in stage/prod)
# -----------------------------------------------------------------------------
# AZURE_KEY_VAULT_URI=https://<your-vault>.vault.azure.net/

# -----------------------------------------------------------------------------
# LangSmith tracing (optional)
# -----------------------------------------------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=agent-orchestration
LANGSMITH_API_KEY=<your-langsmith-api-key>

# -----------------------------------------------------------------------------
# HTTP retry
# -----------------------------------------------------------------------------
AGENT_HTTP_RETRY_MAX_ATTEMPTS=3
